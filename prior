local dragging, dragStart, startPos = false, nil, nil
Main.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = i.Position
        startPos = Main.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

function PS.Disable()
    PS.Active = false
    RemoveESP()
    if ScreenGui then
        ScreenGui:Destroy()
    end
end

function PS.GetSelected()
    return PS.SelectedData
end

function PS.GetSelectedModel()
    if PS.SelectedData then
        local model = getAnimalModel(PS.SelectedData.plot, PS.SelectedData.slot)
        if model then
            PS.SelectedModel = model
            PS.SelectedData.model = model
        end
    end
    return PS.SelectedModel
end

function PS.GetWorldPosition()
    if PS.SelectedData then
        local _, pos = getAnimalModel(PS.SelectedData.plot, PS.SelectedData.slot)
        if pos then
            PS.SelectedData.worldPosition = pos
            return pos
        end
        if PS.SelectedData.worldPosition then
            return PS.SelectedData.worldPosition
        end
    end
    return nil
end

function PS.GetPlotName()
    if PS.SelectedData then
        return PS.SelectedData.plot
    end
    return nil
end

function PS.GetSlot()
    if PS.SelectedData then
        return PS.SelectedData.slot
    end
    return nil
end

function PS.GetOwner()
    if PS.SelectedData then
        return PS.SelectedData.owner
    end
    return nil
end

RefreshList()

task.spawn(function()
    while PS.Active and ScreenGui and ScreenGui.Parent do
        task.wait(0.15)
        pcall(RefreshList)
    end
end)
